# ── Database ──
DATABASE_URL=postgresql+asyncpg://sawtsafe:sawtsafe_dev@localhost:5432/sawtsafe

# ── Redis ──
REDIS_URL=redis://localhost:6379/0

# ── S3 / MinIO (local dev) ──
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=minioadmin
S3_SECRET_KEY=minioadmin123
S3_BUCKET=sawtsafe-evidence

# ── Auth ──
SECRET_KEY=change-me-in-production-use-64-char-random
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Encryption ──
ENCRYPTION_KEY=change-me-32-byte-base64-encoded-key

# ── Environment ──
ENVIRONMENT=development

# ── EU Directive Deadlines (days) ──
ACKNOWLEDGMENT_DAYS=7
FEEDBACK_DEADLINE_DAYS=90
FEEDBACK_WARNING_DAYS=14

# ── Data Retention (GDPR Art. 5(1)(e)) ──
RETENTION_DAYS=365

# ── Session Timeout (minutes of inactivity before auto-logout) ──
SESSION_TIMEOUT_MINUTES=30

# ── Frontend ──
NEXT_PUBLIC_API_URL=http://localhost:8000

# ── GCP (production only) ──
# GCP_PROJECT_ID=wbtool-494011
# GCS_BUCKET=sawtsafe-evidence-prod
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
